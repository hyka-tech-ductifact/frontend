{
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "plugins": ["prettier-plugin-tailwindcss"],
    "overrides": [{
        "files": "*.html",
        "options": {
            "parser": "angular"
        }
    }]
}
